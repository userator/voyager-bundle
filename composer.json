{
    "name": "userator/voyager-bundle",
    "description": "graphql voyager bundle",
    "minimum-stability": "stable",
    "license": "proprietary",
    "type": "symfony-bundle",
    "authors": [
        {
            "name": "userator",
            "email": "userator@ya.ru"
        }
    ],
    "require": {
        "php": "^8.2",
        "symfony/http-kernel": "^5.4",
        "symfony/dependency-injection": "^5.4",
        "symfony/config": "^5.4",
        "twig/twig": "^3.4",
        "symfony/routing": "^5.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "Userator\\VoyagerBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Userator\\VoyagerBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "8.2"
        }
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^5.4"
        }
    }
}
